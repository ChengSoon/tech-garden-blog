---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImmersiveDeck from '../components/media/ImmersiveDeck';
import CoverArt from '../components/post/CoverArt.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import TerminalEgg from '../components/site/TerminalEgg.astro';
import { site } from '../data/site';
import { catalog } from '../data/listening';
import { deriveTopics, getPublishedPosts, pickFeaturedPosts, postSlug } from '../lib/posts';
import { loadFeaturedProjects } from '../lib/projects';
import { absoluteUrl, personJsonLd } from '../lib/seo';

const posts = await getPublishedPosts();
const featured = pickFeaturedPosts(posts, 3);
const topics = deriveTopics(posts, site.interests);
const featuredProjects = await loadFeaturedProjects(3);
const origin = Astro.site?.toString() ?? 'https://blog.lzch.eu.org';
const personLd = personJsonLd({
  name: site.fullName,
  jobTitle: site.role,
  url: absoluteUrl(origin, '/about/'),
  image: absoluteUrl(origin, site.avatar),
  description: site.bio,
  sameAs: site.socials
    .map((s) => s.href)
    .filter((href) => href.startsWith('http')),
});
---
<BaseLayout title="关于" description={site.bio} bodyClass="has-bg-deck" ogImage={site.avatar} canonicalPath="/about/" jsonLd={personLd}>
  <div class="about-shell">
    <ImmersiveDeck client:idle tracks={catalog} mode="bg" />
    <div class="container about-page-content">
      <header class="about-head">
        <p class="eyebrow">Journal</p>
        <h1 class="display">关于</h1>
        <p class="about-head__lede muted">{site.bio}</p>
      </header>

      <div class="about">
        <section class="profile">
          <img
            class="profile__avatar"
            src={site.avatar}
            alt={site.fullName}
            width="96"
            height="96"
            decoding="async"
            fetchpriority="high"
          />
          <div>
            <p class="eyebrow">{site.role}</p>
            <h2 class="display profile__name">{site.fullName}</h2>
            <p class="muted profile__loc">{site.location}</p>
            <p class="profile__bio">{site.bio}</p>
            <div class="profile__links">
              {site.socials.map((s) => (
                <a
                  class="btn"
                  href={s.href}
                  target={s.href.startsWith('http') ? '_blank' : undefined}
                  rel="noreferrer"
                >
                  {s.label}
                </a>
              ))}
              <a class="btn" href="/now">Now</a>
              <a class="btn" href="/uses">Uses</a>
            </div>
            <TerminalEgg />
          </div>
        </section>

        <section>
          <h2 class="display section-title">兴趣方向</h2>
          <div class="tags">
            {topics.map((i) => <span class="badge">{i}</span>)}
          </div>
        </section>

        {featuredProjects.length ? (
          <section>
            <div class="section-head">
              <h2 class="display section-title">作品</h2>
              <a href="/projects">全部作品 →</a>
            </div>
            <div class="project-preview">
              {featuredProjects.map((project) => (
                <ProjectCard project={project} variant="compact" />
              ))}
            </div>
          </section>
        ) : null}

        <section>
          <h2 class="display section-title">代表作</h2>
          <ol class="works">
            {featured.map((p, i) => (
              <li class="work">
                <CoverArt
                  title={p.data.title}
                  slug={postSlug(p)}
                  hero={p.data.hero}
                  tags={p.data.tags}
                  type={p.data.type}
                  variant="thumb"
                />
                <div class="work__body">
                  <span class="n">{String(i + 1).padStart(2, '0')}</span>
                  <a class="display" href={`/posts/${postSlug(p)}/`}>
                    {p.data.title}
                  </a>
                  <p class="muted">{p.data.summary}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page-content {
    position: relative;
    z-index: 1;
    padding: 2.4rem 0 3.5rem;
  }

  .about-head {
    max-width: 40rem;
    margin-bottom: 2rem;
  }

  .about-head h1 {
    margin: 0.35rem 0 0.7rem;
    font-size: clamp(2.2rem, 4vw, 3rem);
  }

  .about-head__lede {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .about {
    display: grid;
    gap: 2.4rem;
  }

  .profile {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 1.25rem;
    padding: 1.35rem 0 1.8rem;
    align-items: start;
    border-bottom: 1px solid var(--border);
  }

  .profile__avatar {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    object-fit: cover;
    object-position: center;
    background: #0b1210;
  }

  .profile__name {
    margin: 0.15rem 0;
    font-size: 2rem;
    line-height: 1.1;
  }

  .profile__loc {
    margin: 0;
    font-size: 0.88rem;
  }

  .profile__bio {
    margin: 0.7rem 0 0.9rem;
    max-width: 40rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .profile__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .section-title {
    margin: 0 0 0.9rem;
    font-size: 1.6rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .works {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }

  .work {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    padding: 1rem 0;
    align-items: center;
    border-top: 1px solid var(--border);
  }

  .work__body {
    display: grid;
    gap: 0.3rem;
  }

  .work .n {
    font-family: var(--font-display);
    color: var(--brass);
    font-size: 1.15rem;
  }

  .work a {
    text-decoration: none;
    color: var(--text);
    font-size: 1.3rem;
    line-height: 1.2;
  }

  .work a:hover {
    color: var(--accent);
  }

  .work p {
    margin: 0;
    font-size: 0.94rem;
  }


  .section-head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.6rem;
    align-items: baseline;
    margin-bottom: 0.2rem;
  }

  .section-head a {
    color: var(--text-muted);
    font: 500 0.8rem/1 var(--font-ui, var(--font-sans));
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .section-head a:hover {
    color: var(--accent);
  }

  .project-preview {
    display: grid;
    gap: 0;
  }

  @media (max-width: 700px) {
    .profile,
    .work {
      grid-template-columns: 1fr;
    }
  }
</style>
