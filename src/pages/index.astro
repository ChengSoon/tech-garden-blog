---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ReadingPaths from '../components/home/ReadingPaths.astro';
import LatestGrowth from '../components/home/LatestGrowth.astro';
import GardenGlimpse from '../components/home/GardenGlimpse.astro';
import SeriesShelf from '../components/home/SeriesShelf.astro';
import ClosingStrip from '../components/home/ClosingStrip.astro';
import ContinueReading from '../components/reader/ContinueReading.astro';
import ImmersiveDeck from '../components/media/ImmersiveDeck';
import { catalog } from '../data/listening';
import {
  getPublishedPosts,
  pickLeadPost,
  toPostCard,
} from '../lib/posts';
import { loadReadingPathDefinitions } from '../lib/load-reading-paths';
import { resolveReadingPaths } from '../lib/reading-paths';
import { getSeriesCards } from '../lib/series';
import '../styles/home.css';
import '../styles/reader.css';

const posts = await getPublishedPosts();
const cards = posts.map(toPostCard);
const bySlug = new Map(cards.map((card) => [card.slug, card]));
const pathDefs = await loadReadingPathDefinitions(posts);
const paths = resolveReadingPaths(pathDefs, bySlug);
const leadPost = pickLeadPost(posts);
const lead = leadPost ? toPostCard(leadPost) : undefined;
const seriesCards = await getSeriesCards(posts);
---
<BaseLayout title="Home" bodyClass="has-bg-deck">
  <div class="home-shell">
    <ImmersiveDeck client:idle tracks={catalog} mode="bg" />
    <div class="container home-shell__content">
      <Hero lead={lead} />
      <ContinueReading posts={cards} />
      {paths.length > 0 ? <ReadingPaths paths={paths} /> : null}
      <LatestGrowth posts={cards.slice(0, 6)} />
      <GardenGlimpse />
      {seriesCards.length > 0 ? <SeriesShelf series={seriesCards} /> : null}
      <ClosingStrip track={catalog[0]} />
    </div>
  </div>
</BaseLayout>
