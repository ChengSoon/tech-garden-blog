---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getProjectById,
  loadProjects,
  projectPath,
  projectStatusLabel,
} from '../../lib/projects';
import { getPublishedPosts, postSlug } from '../../lib/posts';
import { absoluteUrl } from '../../lib/seo';

export async function getStaticPaths() {
  const projects = await loadProjects();
  return projects.map((project) => ({ params: { id: project.id } }));
}

const { id } = Astro.params;
const project = id ? await getProjectById(id) : undefined;
if (!project) {
  return Astro.redirect('/projects/');
}

const posts = await getPublishedPosts();
const related = project.relatedPosts
  .map((slug) => posts.find((post) => postSlug(post) === slug))
  .filter((post): post is (typeof posts)[number] => Boolean(post));

const origin = Astro.site?.toString() ?? 'https://blog.lzch.eu.org';
const ogImage = project.cover || '/og-default.png';
const status = projectStatusLabel[project.status];
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: project.name,
  description: project.summary,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: project.stack.join(', ') || 'Web',
  ...(project.url ? { url: project.url } : {}),
  ...(project.repo ? { codeRepository: project.repo } : {}),
  image: absoluteUrl(origin, ogImage),
};
---
<BaseLayout
  title={project.name}
  description={project.summary}
  ogImage={ogImage}
  canonicalPath={projectPath(project.id)}
  jsonLd={jsonLd}
>
  <article class="container project-detail">
    <nav class="project-detail__crumb" aria-label="面包屑">
      <a href="/projects/">作品</a>
      <span aria-hidden="true">/</span>
      <span>{project.name}</span>
    </nav>

    <header class="project-detail__head">
      <div class="project-detail__meta">
        <span class="badge">{status}</span>
        {project.year ? <span class="muted">{project.year}</span> : null}
        {project.role ? <span class="muted">{project.role}</span> : null}
      </div>
      <h1 class="display project-detail__title">{project.name}</h1>
      <p class="project-detail__summary">{project.summary}</p>
      {project.stack.length ? (
        <ul class="project-detail__stack">
          {project.stack.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      ) : null}
      <div class="project-detail__links">
        {project.url ? (
          <a class="btn btn-primary" href={project.url} target="_blank" rel="noreferrer">访问站点</a>
        ) : null}
        {project.repo ? (
          <a class="btn" href={project.repo} target="_blank" rel="noreferrer">源代码</a>
        ) : null}
        <a class="btn" href="/projects/">全部作品</a>
      </div>
    </header>

    {project.cover ? (
      <figure class="project-detail__cover">
        <img src={project.cover} alt="" width="960" height="540" loading="eager" decoding="async" />
      </figure>
    ) : null}

    {related.length ? (
      <section class="project-detail__related" aria-labelledby="related-posts">
        <h2 id="related-posts" class="display project-detail__section-title">相关文章</h2>
        <ol class="project-detail__posts">
          {related.map((post, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <a href={`/posts/${postSlug(post)}/`}>
                <strong class="display">{post.data.title}</strong>
                <small>{post.data.summary}</small>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ) : null}
  </article>
</BaseLayout>

<style>
  .project-detail {
    max-width: 48rem;
    padding-block: 2rem 3.5rem;
  }

  .project-detail__crumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1.4rem;
    color: var(--text-muted);
    font-size: 0.86rem;
  }

  .project-detail__crumb a {
    color: inherit;
    text-decoration: none;
  }

  .project-detail__crumb a:hover {
    color: var(--accent);
  }

  .project-detail__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    align-items: center;
    margin-bottom: 0.7rem;
  }

  .project-detail__title {
    margin: 0 0 0.7rem;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.15;
  }

  .project-detail__summary {
    margin: 0;
    max-width: 40rem;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .project-detail__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .project-detail__stack li {
    padding: 0.18rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font: 500 0.78rem/1.3 var(--font-ui, var(--font-sans));
    color: var(--text-muted);
  }

  .project-detail__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.2rem;
  }

  .project-detail__cover {
    margin: 1.8rem 0 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-elevated, var(--bg));
  }

  .project-detail__cover img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .project-detail__related {
    margin-top: 2.6rem;
  }

  .project-detail__section-title {
    margin: 0 0 0.6rem;
    font-size: 1.55rem;
  }

  .project-detail__posts {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .project-detail__posts li {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0.8rem;
    padding: 0.95rem 0;
    border-top: 1px solid var(--border);
  }

  .project-detail__posts li > span {
    color: var(--brass, var(--accent));
    font: 1rem var(--font-display);
  }

  .project-detail__posts a {
    display: grid;
    gap: 0.25rem;
    color: inherit;
    text-decoration: none;
  }

  .project-detail__posts strong {
    font-size: 1.2rem;
  }

  .project-detail__posts small {
    color: var(--text-muted);
    line-height: 1.5;
  }
</style>
