---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts, postSlug } from '../../lib/posts';

export async function getStaticPaths() {
  const seriesEntries = await getCollection('series');
  return seriesEntries.map((s) => ({
    params: { id: s.id },
    props: { series: s },
  }));
}

const { series } = Astro.props;
const chapters = (await getPublishedPosts())
  .filter((p) => p.data.series === series.id)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const first = chapters[0];
---
<PageLayout title={series.data.title} lede={series.data.summary}>
  <p class="muted">已发布 {chapters.length} 章</p>
  {first ? (
    <p>
      <a class="btn btn-primary" href={`/posts/${postSlug(first)}/`}>从第 1 章读</a>
    </p>
  ) : null}
  <ol class="chapters">
    {chapters.map((c, i) => (
      <li class="card">
        <a href={`/posts/${postSlug(c)}/`}>
          <span class="muted">第 {i + 1} 章</span>
          <strong>{c.data.title}</strong>
          <span class="muted">{c.data.summary}</span>
        </a>
      </li>
    ))}
  </ol>
</PageLayout>

<style>
  .chapters {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .chapters a {
    display: grid;
    gap: 0.3rem;
    text-decoration: none;
    color: inherit;
  }
</style>
