---
import PageLayout from '../layouts/PageLayout.astro';
import { getPublishedPosts, postSlug } from '../lib/posts';
const posts = (await getPublishedPosts()).slice(0, 5);
const feedPath = '/rss.xml';
---
<PageLayout title="订阅" description="通过 RSS 订阅本站更新" lede="把技术刊交给你自己的阅读器，不受算法时间线打扰。">
  <div class="subscribe">
    <section class="subscribe__primary">
      <p class="eyebrow">RSS / Open feed</p><h2 class="display">跟进下一次生长</h2>
      <div class="feed-box"><code id="feed-url" data-path={feedPath} tabindex="0">{feedPath}</code>
        <button type="button" class="btn btn-primary" id="copy-feed">复制地址</button></div>
      <p id="copy-status" class="muted" aria-live="polite"></p>
      <div class="reader-links"><a class="btn" id="feedly-link" href="https://feedly.com/i/subscription/feed/">用 Feedly 订阅</a>
        <a class="btn" id="inoreader-link" href="https://www.inoreader.com/search/feeds/">用 Inoreader 订阅</a>
        <a class="btn" href="/rss.xml">查看 XML</a></div>
    </section>
    <section><div class="section-head"><h2>最近文章</h2><a href="/articles">全部文章 →</a></div>
      <ol class="recent">{posts.map((post, index) => <li><span>{String(index + 1).padStart(2,'0')}</span>
        <a href={`/posts/${postSlug(post)}/`}><strong class="display">{post.data.title}</strong><small>{post.data.summary}</small></a></li>)}</ol>
    </section>
  </div>
</PageLayout>
<script>
  const code = document.querySelector<HTMLElement>('#feed-url');
  const button = document.querySelector<HTMLButtonElement>('#copy-feed');
  const status = document.querySelector<HTMLElement>('#copy-status');
  const feedUrl = `${window.location.origin}${code?.dataset.path || '/rss.xml'}`;
  if (code) code.textContent = feedUrl;
  document.querySelector<HTMLAnchorElement>('#feedly-link')?.setAttribute('href', `https://feedly.com/i/subscription/feed/${encodeURIComponent(feedUrl)}`);
  document.querySelector<HTMLAnchorElement>('#inoreader-link')?.setAttribute('href', `https://www.inoreader.com/search/feeds/${encodeURIComponent(feedUrl)}`);
  button?.addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(feedUrl); if (status) status.textContent = '已复制到剪贴板'; }
    catch { const selection = window.getSelection(); const range = document.createRange(); if (code) { range.selectNodeContents(code); selection?.removeAllRanges(); selection?.addRange(range); code.focus(); }
      if (status) status.textContent = '请手动复制'; }
  });
</script>
<style>
  .subscribe { display: grid; gap: 2.4rem; max-width: 48rem; }
  .subscribe__primary { padding: 1.4rem 0 1.8rem; border-block: 3px solid var(--accent); }
  .subscribe__primary h2 { margin: .35rem 0 1rem; font-size: clamp(1.8rem,4vw,2.8rem); }
  .feed-box, .reader-links { display: flex; flex-wrap: wrap; gap: .6rem; align-items: center; }
  .feed-box code { flex: 1 1 18rem; padding: .8rem .9rem; border: 1px solid var(--border); background: var(--bg); font: .84rem var(--font-mono); word-break: break-all; }
  #copy-status { min-height: 1.4rem; margin: .55rem 0; }
  .recent { display: grid; gap: 0; margin: 0; padding: 0; list-style: none; }
  .recent li { display: grid; grid-template-columns: 2.5rem 1fr; gap: .8rem; padding: .9rem 0; border-top: 1px solid var(--border); }
  .recent li > span { color: var(--brass); font: 1rem var(--font-display); }
  .recent a { display: grid; gap: .2rem; color: inherit; text-decoration: none; } .recent strong { font-size: 1.2rem; }
  .recent small { color: var(--text-muted); line-height: 1.5; }
</style>
