---
import PageLayout from '../../layouts/PageLayout.astro';
import { getPublishedPosts, postSlug, statusLabel } from '../../lib/posts';
import '../../styles/archive.css';

const posts = await getPublishedPosts();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const years = [...new Set(posts.map((post) => post.data.date.getFullYear()))].sort((a, b) => b - a);
---
<PageLayout title="阅读" lede={`共 ${posts.length} 篇。按类型、主题与生长状态找到下一篇。`}>
  <form class="archive-toolbar" data-archive-filters>
    <label>
      <span>类型</span>
      <select name="type">
        <option value="">全部</option>
        <option value="essay">长文</option>
        <option value="note">笔记</option>
      </select>
    </label>
    <label>
      <span>状态</span>
      <select name="status">
        <option value="">全部</option>
        <option value="seedling">萌芽</option>
        <option value="growing">生长中</option>
        <option value="evergreen">常青</option>
      </select>
    </label>
    <label>
      <span>主题</span>
      <select name="tag">
        <option value="">全部</option>
        {tags.map((tag) => <option value={tag}>#{tag}</option>)}
      </select>
    </label>
    <label>
      <span>年份</span>
      <select name="year">
        <option value="">全部</option>
        {years.map((year) => <option value={year}>{year}</option>)}
      </select>
    </label>
    <label class="archive-toolbar__saved">
      <input type="checkbox" name="saved" value="1" />
      <span>稍后读</span>
    </label>
    <button type="button" class="btn" data-archive-reset>清除</button>
    <output data-archive-count>{posts.length} 篇</output>
  </form>

  <ol class="archive-list" data-archive-list>
    {posts.map((post, index) => {
      const slug = postSlug(post);
      return (
        <li
          class="archive-row"
          data-archive-item
          data-slug={slug}
          data-type={post.data.type}
          data-status={post.data.status}
          data-tags={JSON.stringify(post.data.tags)}
          data-year={post.data.date.getFullYear()}
        >
          <span class="archive-row__number">{String(index + 1).padStart(2, '0')}</span>
          <div class="archive-row__meta">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <span>{post.data.type === 'essay' ? 'Essay' : 'Note'}</span>
            <span><i class="dot" data-status={post.data.status}></i>{statusLabel(post.data.status)}</span>
          </div>
          <a href={`/posts/${slug}/`}>
            <strong class="display">{post.data.title}</strong>
            <span class="muted">{post.data.summary}</span>
          </a>
          <div class="archive-row__side">
            <span>{post.data.tags.slice(0, 2).map((tag) => `#${tag}`).join(' ')}</span>
            <em data-archive-progress></em>
          </div>
        </li>
      );
    })}
  </ol>

  <div class="archive-empty" data-archive-empty hidden>
    <p>没有匹配内容。</p>
    <button type="button" class="btn btn-primary" data-archive-reset>清除筛选</button>
  </div>
</PageLayout>

<script>
  import { startArchive } from '../../lib/archive-client';

  document.addEventListener('astro:page-load', startArchive);
  startArchive();
</script>
