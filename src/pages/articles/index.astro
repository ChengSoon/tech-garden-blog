---
import PageLayout from '../../layouts/PageLayout.astro';
import { getPublishedPosts, postSlug, statusLabel } from '../../lib/posts';

const posts = await getPublishedPosts();
const tags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.date.getFullYear();
  byYear.set(y, [...(byYear.get(y) ?? []), p]);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---
<PageLayout title="文章" lede={`共 ${posts.length} 篇。按时间归档，也可从标签切入。`}>
  <div class="tags">
    {tags.map((t) => (
      <a class="badge" href={`/tags/${t}/`}>#{t}</a>
    ))}
  </div>
  {years.map((year) => (
    <section class="year-block">
      <h2>
        <span>{year}</span>
        <span class="year-count">{(byYear.get(year) ?? []).length}</span>
      </h2>
      <ul>
        {(byYear.get(year) ?? []).map((p) => (
          <li class="card entry">
            <a href={`/posts/${postSlug(p)}/`}>
              <div class="entry__top">
                <time datetime={p.data.date.toISOString()}>
                  {p.data.date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
                </time>
                <span class="badge">{p.data.type === 'essay' ? '长文' : '笔记'}</span>
                <span class="badge">
                  <span class="dot" data-status={p.data.status}></span>
                  {statusLabel(p.data.status)}
                </span>
              </div>
              <strong>{p.data.title}</strong>
              <p class="muted">{p.data.summary}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</PageLayout>

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.7rem;
  }
  .tags a {
    text-decoration: none;
    color: var(--text-muted);
  }
  .tags a:hover {
    color: var(--accent);
    border-color: color-mix(in oklab, var(--accent) 40%, var(--border));
  }
  .year-block { margin-bottom: 2.1rem; }
  .year-block h2 {
    margin: 0 0 0.85rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    font-family: var(--font-ui);
    display: flex;
    align-items: center;
    gap: 0.55rem;
    letter-spacing: 0.04em;
  }
  .year-count {
    display: inline-flex;
    min-width: 1.4rem;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-size: 0.75rem;
    padding: 0.05rem 0.4rem;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }
  .entry {
    padding: 0;
  }
  .entry a {
    display: grid;
    gap: 0.4rem;
    padding: 1rem 1.1rem;
    text-decoration: none;
    color: inherit;
  }
  .entry__top {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .entry time {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--text-muted);
    min-width: 4rem;
  }
  .entry strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .entry p { margin: 0; font-size: 0.95rem; }
</style>
