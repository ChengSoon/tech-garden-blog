---
import ThemeToggle from './ThemeToggle.astro';
import SearchDialog from './SearchDialog';
import Icon from './Icon.astro';
import type { SearchItem } from '../../lib/types';

interface Props {
  searchItems?: SearchItem[];
}

const { searchItems = [] } = Astro.props;
const path = Astro.url.pathname;
const links = [
  { href: '/articles', label: '阅读' },
  { href: '/garden', label: '花园' },
  { href: '/series', label: '系列' },
  { href: '/now', label: 'Now' },
  { href: '/about', label: '关于' },
];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__text">
        <span class="brand__name">Cheng</span>
        <span class="brand__sub">Technical Journal</span>
      </span>
    </a>
    <nav class="nav desktop" aria-label="主导航">
      {links.map((link) => (
        <a href={link.href} aria-current={path.startsWith(link.href) ? 'page' : undefined}>
          {link.label}
        </a>
      ))}
    </nav>
    <div class="site-header__actions">
      <SearchDialog client:idle items={searchItems} />
      <ThemeToggle />
      <details class="mobile-nav">
        <summary class="btn" aria-label="主导航菜单">
          <span class="mobile-nav__open"><Icon name="menu" size={20} /></span>
          <span class="mobile-nav__close"><Icon name="x" size={20} /></span>
        </summary>
        <nav class="mobile-nav__panel" aria-label="移动端主导航">
          {links.map((link) => (
            <a href={link.href} aria-current={path.startsWith(link.href) ? 'page' : undefined}>
              {link.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
  </div>
  <div class="site-header__rule" aria-hidden="true"></div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    height: var(--header-height);
    background: var(--bg);
  }

  .site-header__inner {
    display: flex;
    height: 100%;
    align-items: center;
    gap: 1rem;
  }

  .site-header__rule {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: var(--border-strong);
  }

  .brand {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 0.7rem;
    margin-right: auto;
    color: var(--text);
    text-decoration: none;
  }

  .brand__mark {
    position: relative;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 50%;
    background:
      radial-gradient(circle at 35% 30%, color-mix(in oklab, white 55%, var(--signal)), var(--signal) 55%);
    box-shadow:
      0 0 0 2px color-mix(in oklab, var(--signal) 22%, transparent),
      0 0 0 4px color-mix(in oklab, var(--signal) 8%, transparent);
    animation: motion-mark-pulse 3.6s var(--ease-inout) infinite;
  }

  .brand__mark::after {
    content: "";
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 1px solid color-mix(in oklab, var(--signal) 28%, transparent);
    opacity: 0.7;
    pointer-events: none;
  }

  .brand:hover .brand__mark {
    animation-duration: 1.5s;
    background:
      radial-gradient(circle at 35% 30%, color-mix(in oklab, white 62%, var(--accent)), var(--accent) 58%);
    box-shadow:
      0 0 0 2px color-mix(in oklab, var(--accent) 24%, transparent),
      0 0 0 5px color-mix(in oklab, var(--accent) 10%, transparent);
  }

  .brand:hover .brand__name {
    color: var(--accent);
  }

  .brand__text {
    display: grid;
    line-height: 1.05;
  }

  .brand__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    transition: color var(--motion-base) var(--ease-inout);
  }

  .brand__sub {
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .nav {
    display: flex;
    align-items: stretch;
    gap: 0.2rem;
  }

  .nav a {
    position: relative;
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    padding: 0 0.68rem;
    border-bottom: 2px solid transparent;
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: 0.84rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color var(--motion-base) var(--ease-inout);
  }

  .nav a::after {
    content: "";
    position: absolute;
    left: 0.55rem;
    right: 0.55rem;
    bottom: 0;
    height: 2px;
    background: var(--signal);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.28s var(--ease-out);
  }

  .nav a:hover {
    color: var(--text);
  }

  .nav a:hover::after {
    transform: scaleX(0.55);
    background: var(--border-strong);
  }

  .nav a[aria-current='page'] {
    color: var(--accent);
  }

  .nav a[aria-current='page']::after {
    transform: scaleX(1);
    background: var(--signal);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .mobile-nav {
    position: relative;
    display: none;
  }

  .mobile-nav summary {
    width: 44px;
    height: 44px;
    padding: 0;
    list-style: none;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav__open,
  .mobile-nav__close {
    position: absolute;
    display: grid;
    place-items: center;
  }

  .mobile-nav__close,
  .mobile-nav[open] .mobile-nav__open {
    opacity: 0;
  }

  .mobile-nav[open] .mobile-nav__close {
    opacity: 1;
  }

  .mobile-nav__panel {
    position: absolute;
    top: calc(100% + 0.45rem);
    right: 0;
    display: grid;
    min-width: 10rem;
    padding: 0.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-elevated);
    box-shadow: var(--shadow);
    transform-origin: top right;
    animation: motion-scale-in var(--motion-base) var(--ease-out) both;
  }

  .mobile-nav__panel a {
    display: flex;
    min-height: 44px;
    align-items: center;
    padding: 0.45rem 0.7rem;
    border-left: 2px solid transparent;
    color: var(--text);
    font-size: 0.9rem;
    text-decoration: none;
  }

  .mobile-nav__panel a:hover {
    background: var(--bg-soft);
  }

  .mobile-nav__panel a[aria-current='page'] {
    border-left-color: var(--signal);
    color: var(--accent);
  }

  @media (max-width: 860px) {
    .desktop {
      display: none;
    }

    .mobile-nav {
      display: block;
    }

    .brand__sub {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-nav__panel {
      animation: none;
    }

    .brand__mark,
    .nav a::after {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
