---
import { site } from '../../data/site';

const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="display site-footer__name">{site.name}</p>
      <p class="muted site-footer__tag">{site.tagline}</p>
    </div>
    <nav class="site-footer__links" aria-label="页脚导航">
      <a href="/subscribe">订阅 RSS</a>
      <a href={site.github} rel="noreferrer" target="_blank">GitHub</a>
      <a href="/projects">作品</a>
      <a href="/friends">客串</a>
      <a href="/now">Now</a>
      <a href="/about">关于</a>
    </nav>
    <p class="muted site-footer__copy">© {year} · Printed in pixels</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4.5rem;
    padding: 2rem 0 2.5rem;
    border-top: 1px solid var(--border-strong);
  }

  .site-footer__inner {
    display: grid;
    gap: 0;
  }

  .site-footer__brand {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 1rem;
    padding-bottom: 1rem;
  }

  .site-footer__name {
    margin: 0;
    font-size: 1.8rem;
  }

  .site-footer__tag {
    max-width: 34rem;
    margin: 0;
    font-size: 0.92rem;
  }

  .site-footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.35rem;
    padding: 0.25rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .site-footer__links a {
    position: relative;
    transition: color var(--motion-base) var(--ease-inout), transform var(--motion-base) var(--ease-out);
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    color: var(--text-muted);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .site-footer__links a:hover {
    transform: translate3d(0, -1px, 0);
    color: var(--accent);
  }

  .site-footer__copy {
    margin: 0;
    padding-top: 1rem;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }
</style>
