---
interface Props {
  title?: string;
}
const { title = 'Note' } = Astro.props;
---
<aside class="sidenote">
  <strong class="sidenote__label">{title}</strong>
  <div class="sidenote__body">
    <slot />
  </div>
</aside>

<style>
  .sidenote {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--text-muted);
    border-top: 1px solid var(--brass);
    padding-top: 0.55rem;
    margin: 1.2rem 0;
  }
  .sidenote__label {
    display: block;
    margin-bottom: 0.3rem;
    color: var(--brass);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .sidenote__body :global(p) {
    margin: 0;
  }
  .sidenote__body :global(p + p) {
    margin-top: 0.45em;
  }

  /* Desktop: float into the empty margin beside prose */
  @media (min-width: 1100px) {
    .sidenote {
      float: right;
      clear: right;
      width: 12.5rem;
      margin: 0.15rem -14.5rem 1.1rem 1.25rem;
      padding: 0.15rem 0 0.15rem 0.85rem;
      border-top: 0;
      border-left: 1px solid var(--brass);
    }
  }

  /* When screen can't fit margin notes, keep elegant in-flow card */
  @media (max-width: 1099px) {
    .sidenote {
      background: color-mix(in oklab, var(--brass) 7%, var(--bg-elevated));
      border: 1px solid var(--border);
      border-top: 2px solid var(--brass);
      border-radius: var(--radius-lg);
      padding: 0.8rem 0.95rem;
    }
  }
</style>
