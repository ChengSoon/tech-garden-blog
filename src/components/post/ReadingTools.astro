<div class="reading-tools" role="group" aria-label="阅读设置">
  <button type="button" class="btn reading-tools__btn" data-font-size="down" aria-label="减小字号">A-</button>
  <button type="button" class="btn reading-tools__btn" data-font-size="up" aria-label="增大字号">A+</button>
</div>

<style>
  .reading-tools {
    display: inline-flex;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .reading-tools__btn {
    width: 2.2rem;
    height: 2.2rem;
    padding: 0;
    font-size: 0.85rem;
  }
</style>

<script>
  const root = document.documentElement;
  const key = 'reading-font-scale';
  const saved = Number(localStorage.getItem(key) || '1');
  if (saved && saved !== 1) {
    root.style.setProperty('--content-font-scale', String(saved));
  }

  function apply(scale) {
    const next = Math.min(1.25, Math.max(0.9, scale));
    root.style.setProperty('--content-font-scale', String(next));
    localStorage.setItem(key, String(next));
  }

  document.querySelectorAll('[data-font-size]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const current = Number(getComputedStyle(root).getPropertyValue('--content-font-scale') || '1') || 1;
      const dir = btn.getAttribute('data-font-size');
      apply(current + (dir === 'up' ? 0.05 : -0.05));
    });
  });
</script>
