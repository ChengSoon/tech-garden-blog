---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2);
---
{items.length > 0 ? (
  <nav class="toc" aria-label="章节目录">
    <p class="eyebrow">Contents</p>
    <ol>
      {items.map((h, i) => (
        <li>
          <a href={`#${h.slug}`} data-toc-link={h.slug}>
            <span class="n">{String(i + 1).padStart(2, '0')}</span>
            <span>{h.text}</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
) : null}

<style>
  .toc {
    position: sticky;
    top: calc(var(--header-height) + 1.2rem);
    font-size: 0.86rem;
    padding-left: 0.85rem;
    border-left: 1px solid var(--border);
  }
  .toc .eyebrow {
    margin-bottom: 0.75rem;
  }
  .toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }
  .toc a {
    display: grid;
    grid-template-columns: 1.4rem 1fr;
    gap: 0.45rem;
    color: var(--text-muted);
    text-decoration: none;
    line-height: 1.35;
    font-family: var(--font-ui);
  }
  .toc .n {
    color: var(--brass);
    font-family: var(--font-display);
    font-size: 0.95rem;
  }
  .toc a:hover,
  .toc a[aria-current='true'] {
    color: var(--text);
  }
  .toc a[aria-current='true'] .n {
    color: var(--accent);
  }
  @media (max-width: 960px) {
    .toc { display: none; }
  }
</style>

<script>
  const links = [...document.querySelectorAll('[data-toc-link]')];
  const map = new Map(links.map((a) => [a.dataset.tocLink, a]));
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const id = entry.target.id;
        for (const a of links) a.removeAttribute('aria-current');
        map.get(id)?.setAttribute('aria-current', 'true');
      }
    },
    { rootMargin: '-20% 0px -70% 0px', threshold: 0 },
  );
  for (const id of map.keys()) {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  }
</script>
