---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2);
---
{items.length > 0 ? (
  <details class="mobile-toc">
    <summary>本章目录 · {items.length}</summary>
    <ol>
      {items.map((h) => (
        <li>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
  </details>
) : null}

<style>
  .mobile-toc {
    display: none;
    margin: 0 0 1.4rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-elevated);
    padding: 0.2rem 0.85rem 0.2rem;
    font-family: var(--font-ui);
  }
  .mobile-toc summary {
    cursor: pointer;
    padding: 0.7rem 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    list-style: none;
  }
  .mobile-toc summary::-webkit-details-marker { display: none; }
  .mobile-toc[open] summary {
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.55rem;
    color: var(--text);
  }
  .mobile-toc ol {
    margin: 0 0 0.75rem;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.4rem;
  }
  .mobile-toc a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.92rem;
  }
  .mobile-toc a:hover { color: var(--accent); }
  @media (max-width: 960px) {
    .mobile-toc { display: block; }
  }
</style>
