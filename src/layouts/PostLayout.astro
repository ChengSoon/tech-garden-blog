---
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/post/PostMeta.astro';
import TableOfContents from '../components/post/TableOfContents.astro';
import ReadingProgress from '../components/post/ReadingProgress.astro';
import NeighborCards from '../components/post/NeighborCards.astro';
import SeriesNav from '../components/post/SeriesNav.astro';
import Backlinks from '../components/post/Backlinks.astro';
import CodeEnhance from '../components/post/CodeEnhance.astro';
import ReadingTools from '../components/post/ReadingTools.astro';
import ReadingSession from '../components/reader/ReadingSession.astro';
import MobileToc from '../components/post/MobileToc.astro';
import CoverArt from '../components/post/CoverArt.astro';
import AuthorCard from '../components/post/AuthorCard.astro';
import type { GraphNode, NeighborNode } from '../lib/types';
import { site } from '../data/site';
import { absoluteUrl, blogPostingJsonLd } from '../lib/seo';
import '../styles/reader.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface SeriesItem {
  slug: string;
  title: string;
}
interface Props {
  title: string;
  description: string;
  type: string;
  status: string;
  date: Date;
  tags: string[];
  readingMinutes: number;
  headings: Heading[];
  neighbors: NeighborNode[];
  backlinks: GraphNode[];
  seriesId?: string;
  prev?: SeriesItem | null;
  next?: SeriesItem | null;
  slug: string;
  hero?: string;
}
const props = Astro.props;
const showToc = props.type === 'essay' && props.headings.some((h) => h.depth === 2);
const isEssay = props.type === 'essay';
const origin = Astro.site?.toString() ?? 'https://blog.lzch.eu.org';
const canonicalPath = `/posts/${props.slug}/`;
const ogImage = props.hero || '/avatar.webp';
const postJsonLd = blogPostingJsonLd({
  headline: props.title,
  description: props.description,
  datePublished: props.date,
  url: absoluteUrl(origin, canonicalPath),
  image: absoluteUrl(origin, ogImage),
  authorName: site.fullName,
  authorUrl: absoluteUrl(origin, '/about/'),
});
---
<BaseLayout
  title={props.title}
  description={props.description}
  ogImage={ogImage}
  ogType="article"
  canonicalPath={canonicalPath}
  jsonLd={postJsonLd}
>
  <ReadingProgress />
  <ReadingSession slug={props.slug} />
  <article class="container post" data-article data-slug={props.slug} data-line-width="normal">
    {isEssay ? (
      <CoverArt
        title={props.title}
        slug={props.slug}
        hero={props.hero}
        tags={props.tags}
        type={props.type}
        variant="hero"
      />
    ) : null}
    <div class={`post__grid ${showToc ? 'has-toc' : ''}`}>
      <div class="post__main">
        <header class="post__header">
          <div class="post__header-top">
            <p class="eyebrow">{isEssay ? 'Essay' : 'Note'}</p>
            <ReadingTools slug={props.slug} title={props.title} />
          </div>
          <h1 class="display">{props.title}</h1>
          <p class="post__summary">{props.description}</p>
          <PostMeta
            date={props.date}
            readingMinutes={props.readingMinutes}
            tags={props.tags}
            status={props.status}
            type={props.type}
          />
          <hr class="rule" />
        </header>
        {showToc ? <MobileToc headings={props.headings} /> : null}
        <div class={`prose ${isEssay ? 'prose--essay' : 'prose--note'}`}>
          <slot />
        </div>
        {props.type === 'note' ? <Backlinks backlinks={props.backlinks} /> : null}
        <SeriesNav seriesId={props.seriesId} prev={props.prev} next={props.next} />
        <NeighborCards neighbors={props.neighbors} />
        {props.type === 'essay' ? <Backlinks backlinks={props.backlinks} /> : null}
        <AuthorCard />
      </div>
      {showToc ? (
        <aside class="post__aside">
          <TableOfContents headings={props.headings} />
        </aside>
      ) : null}
    </div>
  </article>
  <CodeEnhance />
</BaseLayout>

<style>
  .post {
    padding: 2.2rem 0 4rem;
  }
  .post__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.4rem;
    align-items: start;
  }
  .post__grid.has-toc {
    grid-template-columns: minmax(0, 1fr) 200px;
  }
  .post__main {
    min-width: 0;
  }
  .post__header {
    max-width: 42rem;
    margin-bottom: 1.4rem;
  }
  .post__header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }
  .post__main h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.1rem, 4vw, 3.1rem);
    max-width: 16em;
  }
  .post__header .rule {
    margin-top: 1.25rem;
  }
  /* clear floats from sidenotes */
  :global(.prose--essay)::after {
    content: "";
    display: table;
    clear: both;
  }
  :global(.prose--note > p:first-of-type::first-letter) {
    float: none;
    font-size: inherit;
    line-height: inherit;
    padding: 0;
    color: inherit;
    font-weight: inherit;
  }
  @media (max-width: 960px) {
    .post__grid.has-toc {
      grid-template-columns: 1fr;
    }
  }
</style>
